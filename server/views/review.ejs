<% layout('layout') -%>
    <% block('title', 'Перевод задачи в ревью' ); -%>

        <div class="container my-5">
            <div class="row">
                <div class="col-12 col-lg-10 mx-auto">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h2 class="mb-0">
                            <i class="bi bi-check2-square me-2"></i>Перевод задачи в ревью
                        </h2>
                        <a href="/" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-arrow-left me-1"></i>На главную
                        </a>
                    </div>

                    <% if (error) { %>
                        <div class="alert alert-danger" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            <%= error %>
                        </div>
                        <% } %>

                            <div class="card shadow-sm">
                                <div class="card-header bg-primary text-white">
                                    <h5 class="mb-0">
                                        <i class="bi bi-send me-2"></i>Создать ревью
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <form id="reviewForm">
                                        <div class="mb-3">
                                            <label for="taskKey" class="form-label">
                                                <strong>Задача (Jira)</strong> <span class="text-danger">*</span>
                                            </label>
                                            <select class="form-select" id="taskKey" name="taskKey" required>
                                                <option value="">Загрузка задач...</option>
                                            </select>
                                            <div class="form-text">Выберите задачу из списка или начните вводить для поиска. Показываются ваши задачи в статусе "In Progress"</div>
                                        </div>

                                        <div class="mb-3">
                                            <label for="channelId" class="form-label">
                                                <strong>Канал</strong> <span class="text-danger">*</span>
                                            </label>
                                            <select class="form-select" id="channelId" name="channelId" required>
                                                <option value="">Выберите канал...</option>
                                                <% if (availableChannels && availableChannels.length> 0) { %>
                                                    <% availableChannels.forEach((channel, index)=> { %>
                                                        <option value="<%= channel.id %>"
                                                            <%=(availableChannels.length===1) ? 'selected' : '' %>><%=
                                                                channel.name %>
                                                        </option>
                                                        <% }); %>
                                                            <% } else { %>
                                                                <option value="" disabled>Нет доступных каналов</option>
                                                                <% } %>
                                            </select>
                                            <div class="form-text">Выберите канал, в который будет отправлено сообщение
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">
                                                <strong>Тип контента</strong>
                                            </label>
                                            <div class="btn-group w-100" role="group" id="contentTypeGroup">
                                                <input type="radio" class="btn-check" name="contentType"
                                                    id="contentTypePR" value="pr" checked>
                                                <label class="btn btn-outline-primary" for="contentTypePR">
                                                    <i class="bi bi-git me-1"></i>Pull Request
                                                </label>

                                                <input type="radio" class="btn-check" name="contentType"
                                                    id="contentTypeMessage" value="message">
                                                <label class="btn btn-outline-primary" for="contentTypeMessage">
                                                    <i class="bi bi-chat-text me-1"></i>Сообщение
                                                </label>
                                            </div>
                                        </div>

                                        <div class="mb-3" id="mergeRequestContainer">
                                            <label for="mergeRequest" class="form-label">
                                                <strong>Merge Request URL</strong>
                                            </label>
                                            <input type="url" class="form-control" id="mergeRequest" name="mergeRequest"
                                                placeholder="https://gitlab.example.com/project/-/merge_requests/123">
                                            <div class="form-text">Ссылка на Merge Request в GitLab</div>
                                        </div>

                                        <div class="mb-3" id="messageContainer" style="display: none;">
                                            <label for="messageText" class="form-label">
                                                <strong>Текст сообщения</strong>
                                            </label>
                                            <div class="message-input-wrapper">
                                                <textarea class="form-control" id="messageText" name="messageText"
                                                    rows="4"
                                                    placeholder="Введите текст сообщения, которое будет отправлено в канал"></textarea>

                                                <!-- Панель форматирования Markdown -->
                                                <div class="markdown-toolbar">
                                                    <div class="toolbar-group">
                                                        <button type="button" class="toolbar-btn" title="Жирный текст"
                                                            onclick="insertMarkdown('**', '**')">
                                                            <i class="bi bi-type-bold"></i>
                                                        </button>
                                                        <button type="button" class="toolbar-btn" title="Курсив"
                                                            onclick="insertMarkdown('*', '*')">
                                                            <i class="bi bi-type-italic"></i>
                                                        </button>
                                                        <button type="button" class="toolbar-btn" title="Зачеркнутый"
                                                            onclick="insertMarkdown('~~', '~~')">
                                                            <i class="bi bi-type-strikethrough"></i>
                                                        </button>
                                                        <button type="button" class="toolbar-btn" title="Заголовок"
                                                            onclick="insertMarkdown('# ', '')">
                                                            <i class="bi bi-type-h1"></i>
                                                        </button>
                                                        <button type="button" class="toolbar-btn" title="Ссылка"
                                                            onclick="insertLink()">
                                                            <i class="bi bi-link-45deg"></i>
                                                        </button>
                                                        <button type="button" class="toolbar-btn" title="Код"
                                                            onclick="insertMarkdown('`', '`')">
                                                            <i class="bi bi-code"></i>
                                                        </button>
                                                    </div>
                                                    <div class="toolbar-divider"></div>
                                                    <div class="toolbar-group">
                                                        <button type="button" class="toolbar-btn" title="Список"
                                                            onclick="insertMarkdown('- ', '')">
                                                            <i class="bi bi-list-ul"></i>
                                                        </button>
                                                        <button type="button" class="toolbar-btn" title="Цитата"
                                                            onclick="insertMarkdown('> ', '')">
                                                            <i class="bi bi-quote"></i>
                                                        </button>
                                                        <button type="button" class="toolbar-btn" title="Блок кода"
                                                            onclick="insertCodeBlock()">
                                                            <i class="bi bi-code-square"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="form-text">Текст сообщения, которое будет отправлено в канал.
                                                Используйте панель форматирования для добавления Markdown разметки</div>
                                        </div>

                                        <div class="mb-3">
                                            <label for="reviewers" class="form-label">
                                                <strong>Ревьюверы (опционально)</strong>
                                            </label>
                                            <input type="text" class="form-control" id="reviewers" name="reviewers"
                                                placeholder="Сначала выберите канал">
                                            <div class="form-text">Выберите одного или нескольких ревьюверов. Если не
                                                выбрано, будет назначен автоматически</div>
                                        </div>

                                        <div class="alert alert-info" role="alert">
                                            <i class="bi bi-info-circle me-2"></i>
                                            <strong>Как это работает:</strong><br>
                                            • Задача будет переведена в статус <strong>IN REVIEW</strong> в Jira<br>
                                            • Сообщение будет отправлено в выбранный канал<br>
                                            • Если ревьювер не указан, он будет назначен автоматически (если
                                            настроено)<br>
                                            • Если задача уже в статусе To Do, она сначала переведется в In Progress
                                        </div>

                                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                            <button type="button" class="btn btn-outline-secondary"
                                                onclick="previewMessage()">
                                                <i class="bi bi-eye me-1"></i>Предпросмотр
                                            </button>
                                            <button type="submit" class="btn btn-primary" id="submitBtn">
                                                <i class="bi bi-send me-1"></i>Отправить в канал
                                            </button>
                                        </div>
                                    </form>

                                    <div id="previewContainer" class="mt-4" style="display: none;">
                                        <div class="card">
                                            <div class="card-header">
                                                <strong>Предпросмотр сообщения:</strong>
                                            </div>
                                            <div class="card-body">
                                                <div id="previewContent"
                                                    style="white-space: pre-wrap; font-family: monospace;"></div>
                                            </div>
                                        </div>
                                    </div>

                                    <div id="resultContainer" class="mt-4" style="display: none;"></div>
                                </div>
                            </div>
                </div>
            </div>
        </div>

        <link href="https://cdn.jsdelivr.net/npm/tom-select@2.4.2/dist/css/tom-select.bootstrap5.min.css"
            rel="stylesheet">
        <script src="https://cdn.jsdelivr.net/npm/tom-select@2.4.2/dist/js/tom-select.complete.min.js"></script>

        <script>
            let reviewersSelect = null;
            let tasksSelect = null;

            // Функция загрузки задач пользователя
            async function loadUserTasks(searchTerm = '') {
                const taskSelect = document.getElementById('taskKey');

                // Уничтожаем предыдущий экземпляр Tom Select, если он существует
                if (tasksSelect) {
                    tasksSelect.destroy();
                    tasksSelect = null;
                }

                try {
                    const url = searchTerm 
                        ? `/review/api/user-tasks?search=${encodeURIComponent(searchTerm)}`
                        : '/review/api/user-tasks';
                    
                    const response = await fetch(url);
                    const data = await response.json();

                    if (data.error) {
                        taskSelect.innerHTML = `<option value="">Ошибка: ${data.error}</option>`;
                        taskSelect.disabled = true;
                        return;
                    }

                    if (data.tasks && data.tasks.length > 0) {
                        // Инициализируем Tom Select
                        tasksSelect = new TomSelect('#taskKey', {
                            maxItems: 1,
                            valueField: 'value',
                            labelField: 'text',
                            searchField: ['key', 'summary', 'text'],
                            create: function(input) {
                                // Позволяем создавать новую опцию, если пользователь ввел ключ задачи вручную
                                const value = input.trim().toUpperCase();
                                if (/^(CASEM|REN)-\d+$/.test(value)) {
                                    return {
                                        value: value,
                                        text: value,
                                        key: value,
                                        summary: ''
                                    };
                                }
                                return null;
                            },
                            createOnBlur: true,
                            options: data.tasks,
                            placeholder: 'Выберите задачу или начните вводить для поиска...',
                            render: {
                                option: (item, escape) => {
                                    if (item.summary) {
                                        return `
                                            <div>
                                                <strong>${escape(item.key)}</strong>
                                                <div class="text-muted small">${escape(item.summary)}</div>
                                            </div>
                                        `;
                                    }
                                    return `<div>${escape(item.text)}</div>`;
                                },
                                item: (item, escape) => {
                                    return `<div>${escape(item.key || item.value)}</div>`;
                                },
                                no_results: () => {
                                    return '<div class="no-results">Задачи не найдены. Попробуйте ввести ключ задачи вручную (например: CASEM-123)</div>';
                                }
                            },
                            load: function(query, callback) {
                                // Загружаем задачи при поиске
                                if (!query.length) {
                                    callback();
                                    return;
                                }
                                
                                fetch(`/review/api/user-tasks?search=${encodeURIComponent(query)}`)
                                    .then(response => response.json())
                                    .then(data => {
                                        if (data.error) {
                                            callback();
                                            return;
                                        }
                                        callback(data.tasks || []);
                                    })
                                    .catch(() => {
                                        callback();
                                    });
                            },
                            onChange: function(value) {
                                // При выборе задачи загружаем её детали и заполняем Merge Request
                                if (!value) return;
                                
                                const taskKey = value;
                                loadTaskDetails(taskKey);
                            }
                        });
                    } else {
                        // Если нет задач, все равно инициализируем Tom Select с возможностью ввода вручную
                        tasksSelect = new TomSelect('#taskKey', {
                            maxItems: 1,
                            valueField: 'value',
                            labelField: 'text',
                            create: function(input) {
                                const value = input.trim().toUpperCase();
                                if (/^(CASEM|REN)-\d+$/.test(value)) {
                                    return {
                                        value: value,
                                        text: value,
                                        key: value,
                                        summary: ''
                                    };
                                }
                                return null;
                            },
                            createOnBlur: true,
                            placeholder: 'Введите ключ задачи (например: CASEM-123)',
                            options: [],
                            onChange: function(value) {
                                // При выборе задачи загружаем её детали и заполняем Merge Request
                                if (!value) return;
                                
                                const taskKey = value;
                                loadTaskDetails(taskKey);
                            }
                        });
                    }
                } catch (error) {
                    taskSelect.innerHTML = `<option value="">Ошибка загрузки: ${error.message}</option>`;
                    taskSelect.disabled = true;
                }
            }

            // Функция загрузки деталей задачи и автоматического заполнения Merge Request
            async function loadTaskDetails(taskKey) {
                if (!taskKey) return;

                try {
                    const response = await fetch(`/review/api/task-details?taskKey=${encodeURIComponent(taskKey)}`);
                    const data = await response.json();

                    if (data.error) {
                        console.warn('Could not load task details:', data.error);
                        return;
                    }

                    // Заполняем поле Merge Request, если оно есть и если выбран тип "Pull Request"
                    const contentTypePR = document.getElementById('contentTypePR');
                    if (contentTypePR && contentTypePR.checked && data.mergeRequestUrl) {
                        const mergeRequestInput = document.getElementById('mergeRequest');
                        if (mergeRequestInput && !mergeRequestInput.value.trim()) {
                            mergeRequestInput.value = data.mergeRequestUrl;
                        }
                    }
                } catch (error) {
                    console.warn('Error loading task details:', error);
                }
            }

            // Функция загрузки пользователей канала
            async function loadChannelUsers(channelId) {
                const reviewersInput = document.getElementById('reviewers');

                // Уничтожаем предыдущий экземпляр Tom Select, если он существует
                if (reviewersSelect) {
                    reviewersSelect.destroy();
                    reviewersSelect = null;
                }

                if (!channelId) {
                    reviewersInput.placeholder = 'Сначала выберите канал';
                    reviewersInput.disabled = true;
                    return;
                }

                reviewersInput.placeholder = 'Загрузка пользователей...';
                reviewersInput.disabled = true;

                try {
                    const response = await fetch(`/review/api/channel-users?channelId=${encodeURIComponent(channelId)}`);
                    const data = await response.json();

                    if (data.error) {
                        reviewersInput.placeholder = `Ошибка: ${data.error}`;
                        reviewersInput.disabled = true;
                        return;
                    }

                    if (data.users && data.users.length > 0) {
                        // Создаем опции для Tom Select
                        const options = data.users.map(user => ({
                            value: `@${user.username}`,
                            text: `${user.displayName} (@${user.username})`,
                            username: user.username,
                            displayName: user.displayName
                        }));

                        // Включаем поле ПЕРЕД инициализацией Tom Select
                        reviewersInput.disabled = false;

                        // Инициализируем Tom Select
                        reviewersSelect = new TomSelect('#reviewers', {
                            maxItems: null, // Неограниченное количество выбора
                            valueField: 'value',
                            labelField: 'text',
                            searchField: ['text', 'username', 'displayName'],
                            create: false,
                            preload: true,
                            options: options,
                            placeholder: 'Выберите ревьюверов...',
                            disabled: false, // Явно указываем, что не disabled
                            render: {
                                option: (item, escape) => {
                                    const displayName = item.displayName || item.username;
                                    return `
                                <div>
                                    <strong>${escape(displayName)}</strong>
                                    <span class="text-muted"> — ${escape(item.username)}</span>
                                </div>
                            `;
                                },
                                item: (item, escape) => `<div>${escape(item.value)}</div>`
                            }
                        });

                        // Убеждаемся, что Tom Select активирован
                        if (reviewersSelect) {
                            reviewersSelect.enable();
                        }
                    } else {
                        reviewersInput.placeholder = 'В канале нет пользователей';
                        reviewersInput.disabled = true;
                    }
                } catch (error) {
                    reviewersInput.placeholder = `Ошибка загрузки: ${error.message}`;
                    reviewersInput.disabled = true;
                }
            }

            // Загрузка пользователей канала при выборе канала
            document.getElementById('channelId').addEventListener('change', async function () {
                await loadChannelUsers(this.value);
            });

            // Автоматическая загрузка при загрузке страницы
            document.addEventListener('DOMContentLoaded', () => {
                // Загружаем задачи пользователя
                loadUserTasks();

                // Загружаем пользователей канала, если канал уже выбран
                const channelSelect = document.getElementById('channelId');
                const selectedChannelId = channelSelect.value;
                if (selectedChannelId) {
                    loadChannelUsers(selectedChannelId);
                }
            });

            // Переключение между PR и Message
            document.querySelectorAll('input[name="contentType"]').forEach(radio => {
                radio.addEventListener('change', function () {
                    const isPR = this.value === 'pr';
                    document.getElementById('mergeRequestContainer').style.display = isPR ? 'block' : 'none';
                    document.getElementById('messageContainer').style.display = isPR ? 'none' : 'block';

                    // Обновляем обязательность полей
                    document.getElementById('mergeRequest').required = isPR;
                    document.getElementById('messageText').required = !isPR;
                });
            });

            document.getElementById('reviewForm').addEventListener('submit', async (e) => {
                e.preventDefault();

                const submitBtn = document.getElementById('submitBtn');
                const originalText = submitBtn.innerHTML;
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Отправка...';

                // Получаем выбранных ревьюверов
                let reviewer = null;
                if (reviewersSelect && reviewersSelect.items && reviewersSelect.items.length > 0) {
                    reviewer = reviewersSelect.items.join(', ');
                }

                // Получаем тип контента
                const contentType = document.querySelector('input[name="contentType"]:checked').value;
                const mergeRequest = contentType === 'pr' ? document.getElementById('mergeRequest').value.trim() : null;
                const messageText = contentType === 'message' ? document.getElementById('messageText').value.trim() : null;

                // Получаем выбранную задачу
                let taskKey = null;
                if (tasksSelect && tasksSelect.items && tasksSelect.items.length > 0) {
                    taskKey = tasksSelect.items[0];
                } else {
                    const taskSelectElement = document.getElementById('taskKey');
                    taskKey = taskSelectElement.value ? taskSelectElement.value.trim() : null;
                }

                if (!taskKey) {
                    alert('Пожалуйста, выберите задачу');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                    return;
                }

                const formData = {
                    taskKey: taskKey,
                    channelId: document.getElementById('channelId').value,
                    contentType: contentType,
                    mergeRequest: mergeRequest,
                    messageText: messageText,
                    reviewer: reviewer
                };

                try {
                    const response = await fetch('/review/api/send', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(formData)
                    });

                    const result = await response.json();
                    const resultContainer = document.getElementById('resultContainer');

                    if (result.success) {
                        resultContainer.innerHTML = `
                    <div class="alert alert-success" role="alert">
                        <i class="bi bi-check-circle me-2"></i>
                        <strong>Успешно!</strong> ${result.message}
                    </div>
                `;
                        resultContainer.style.display = 'block';
                        document.getElementById('reviewForm').reset();

                        // Сбрасываем Tom Select для задач
                        if (tasksSelect) {
                            tasksSelect.clear();
                            tasksSelect.destroy();
                            tasksSelect = null;
                        }
                        // Перезагружаем задачи
                        loadUserTasks();

                        // Сбрасываем Tom Select для ревьюверов
                        if (reviewersSelect) {
                            reviewersSelect.clear();
                            reviewersSelect.destroy();
                            reviewersSelect = null;
                        }
                        document.getElementById('reviewers').placeholder = 'Сначала выберите канал';
                        document.getElementById('reviewers').disabled = true;
                        document.getElementById('mergeRequestContainer').style.display = 'block';
                        document.getElementById('messageContainer').style.display = 'none';
                    } else {
                        resultContainer.innerHTML = `
                    <div class="alert alert-danger" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Ошибка:</strong> ${result.error || 'Неизвестная ошибка'}
                    </div>
                `;
                        resultContainer.style.display = 'block';
                    }
                } catch (error) {
                    document.getElementById('resultContainer').innerHTML = `
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    <strong>Ошибка:</strong> ${error.message}
                </div>
            `;
                    document.getElementById('resultContainer').style.display = 'block';
                } finally {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                }
            });

            async function previewMessage() {
                // Получаем выбранную задачу
                let taskKey = null;
                if (tasksSelect && tasksSelect.items && tasksSelect.items.length > 0) {
                    taskKey = tasksSelect.items[0];
                } else {
                    const taskSelectElement = document.getElementById('taskKey');
                    taskKey = taskSelectElement.value ? taskSelectElement.value.trim() : null;
                }
                const contentType = document.querySelector('input[name="contentType"]:checked').value;
                const mergeRequest = contentType === 'pr' ? document.getElementById('mergeRequest').value.trim() : null;
                const messageText = contentType === 'message' ? document.getElementById('messageText').value.trim() : null;
                let reviewer = null;
                if (reviewersSelect && reviewersSelect.items && reviewersSelect.items.length > 0) {
                    reviewer = reviewersSelect.items.join(', ');
                }

                if (!taskKey) {
                    alert('Укажите ключ задачи для предпросмотра');
                    return;
                }

                try {
                    const params = new URLSearchParams({
                        taskKey: taskKey,
                        contentType: contentType,
                        mergeRequest: mergeRequest || '',
                        messageText: messageText || '',
                        reviewer: reviewer || ''
                    });

                    const response = await fetch(`/review/api/preview?${params.toString()}`);
                    const data = await response.json();

                    if (data.error) {
                        alert('Ошибка: ' + data.error);
                        return;
                    }

                    const previewContainer = document.getElementById('previewContainer');
                    const previewContent = document.getElementById('previewContent');
                    previewContent.textContent = data.message;
                    previewContainer.style.display = 'block';
                } catch (error) {
                    alert('Ошибка при получении предпросмотра: ' + error.message);
                }
            }

            // Функции для панели форматирования Markdown
            function insertMarkdown(before, after) {
                const textarea = document.getElementById('messageText');
                const start = textarea.selectionStart;
                const end = textarea.selectionEnd;
                const selectedText = textarea.value.substring(start, end);
                const textBefore = textarea.value.substring(0, start);
                const textAfter = textarea.value.substring(end);

                let insertText;
                if (selectedText) {
                    // Если есть выделенный текст, оборачиваем его
                    insertText = before + selectedText + after;
                } else {
                    // Если нет выделения, вставляем маркеры и помещаем курсор между ними
                    insertText = before + after;
                }

                textarea.value = textBefore + insertText + textAfter;

                // Устанавливаем позицию курсора
                if (selectedText) {
                    textarea.selectionStart = start + before.length + selectedText.length + after.length;
                    textarea.selectionEnd = textarea.selectionStart;
                } else {
                    textarea.selectionStart = start + before.length;
                    textarea.selectionEnd = textarea.selectionStart;
                }

                textarea.focus();
            }

            function insertLink() {
                const textarea = document.getElementById('messageText');
                const start = textarea.selectionStart;
                const end = textarea.selectionEnd;
                const selectedText = textarea.value.substring(start, end);
                const textBefore = textarea.value.substring(0, start);
                const textAfter = textarea.value.substring(end);

                let linkText, linkUrl;
                if (selectedText) {
                    // Если есть выделенный текст, используем его как текст ссылки
                    linkText = selectedText;
                    linkUrl = 'https://';
                } else {
                    // Если нет выделения, используем стандартные значения
                    linkText = 'текст ссылки';
                    linkUrl = 'https://';
                }

                const insertText = `[${linkText}](${linkUrl})`;
                textarea.value = textBefore + insertText + textAfter;

                // Устанавливаем позицию курсора на URL
                if (selectedText) {
                    textarea.selectionStart = start + linkText.length + 3; // 3 = "[".length + "](".length
                    textarea.selectionEnd = textarea.selectionStart + linkUrl.length;
                } else {
                    textarea.selectionStart = start + linkText.length + 3;
                    textarea.selectionEnd = textarea.selectionStart + linkUrl.length;
                }

                textarea.focus();
            }

            function insertCodeBlock() {
                const textarea = document.getElementById('messageText');
                const start = textarea.selectionStart;
                const end = textarea.selectionEnd;
                const selectedText = textarea.value.substring(start, end);
                const textBefore = textarea.value.substring(0, start);
                const textAfter = textarea.value.substring(end);

                let insertText;
                if (selectedText) {
                    // Если есть выделенный текст, оборачиваем его в блок кода
                    insertText = '```\n' + selectedText + '\n```';
                } else {
                    // Если нет выделения, вставляем пустой блок кода
                    insertText = '```\n\n```';
                }

                textarea.value = textBefore + insertText + textAfter;

                // Устанавливаем позицию курсора
                if (selectedText) {
                    textarea.selectionStart = start + insertText.length;
                    textarea.selectionEnd = textarea.selectionStart;
                } else {
                    textarea.selectionStart = start + 4; // Позиция после "```\n"
                    textarea.selectionEnd = textarea.selectionStart;
                }

                textarea.focus();
            }
        </script>

