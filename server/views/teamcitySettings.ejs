<% layout('layout') -%>
<% block('title', 'Настройки уведомлений TeamCity' ); -%>

<div class="container my-5">
    <div class="row">
        <div class="col-12 col-lg-10 mx-auto">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">
                    <i class="bi bi-gear me-2"></i>Настройки уведомлений TeamCity
                </h2>
                <a href="/" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left me-1"></i>Назад
                </a>
            </div>

            <% if (status === 'success') { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i><strong>Операция выполнена успешно!</strong>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } else if (status === 'error') { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i><strong>Произошла ошибка.</strong>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>

            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-bell me-2"></i>Список настроек
                    </h5>
                    <a href="/teamcity/form" class="btn btn-primary btn-sm">
                        <i class="bi bi-plus-circle me-1"></i>Добавить настройку
                    </a>
                </div>
                <div class="card-body">

                    <% if (!notifications || notifications.length === 0) { %>
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            <p class="mb-0">Нет настроек уведомлений. <a href="/teamcity/form">Создайте первую настройку</a></p>
                        </div>
                    <% } else { %>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead>
                                    <tr>
                                        <th><i class="bi bi-tag me-1"></i>Конфигурация билда</th>
                                        <th><i class="bi bi-hash me-1"></i>Канал</th>
                                        <th class="text-center"><i class="bi bi-bell me-1"></i>Уведомлять</th>
                                        <th class="text-center"><i class="bi bi-power me-1"></i>Статус</th>
                                        <th><i class="bi bi-clock-history me-1"></i>Последний билд</th>
                                        <th class="text-end">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% notifications.forEach(notif => { %>
                                        <tr>
                                            <td>
                                                <div>
                                                    <strong>
                                                        <%= notif.build_config_name || notif.build_config_id %>
                                                    </strong>
                                                    <br>
                                                    <small class="text-muted">
                                                        <%= notif.build_config_id %>
                                                    </small>
                                                </div>
                                            </td>
                                            <td>
                                                <%= notif.channel_name || notif.channel_id %>
                                            </td>
                                            <td class="text-center">
                                                <% const notifyOnLabels = { 'all': 'Все билды', 'success': 'Успешные', 'failure': 'Неуспешные' }; %>
                                                <span class="badge bg-info">
                                                    <%= notifyOnLabels[notif.notify_on] || notif.notify_on %>
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                <% if (notif.is_enabled === 1 || notif.is_enabled === true) { %>
                                                    <span class="badge bg-success">Включено</span>
                                                <% } else { %>
                                                    <span class="badge bg-secondary">Отключено</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <% if (notif.last_build_id && notif.last_checked_at) { %>
                                                    <small class="text-muted">
                                                        <i class="bi bi-calendar3 me-1"></i><%= notif.last_checked_at %> UTC
                                                    </small>
                                                <% } else { %>
                                                    <small class="text-muted">
                                                        <i class="bi bi-dash-circle me-1"></i>Еще не проверялось
                                                    </small>
                                                <% } %>
                                            </td>
                                            <td class="text-end">
                                                <a href="/teamcity/form?id=<%= notif.id %>"
                                                    class="btn btn-outline-primary btn-sm me-2" title="Редактировать">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form method="POST" action="/teamcity/delete" style="display: inline;"
                                                    onsubmit="return confirm('Вы уверены, что хотите удалить эту настройку?');">
                                                    <input type="hidden" name="id" value="<%= notif.id %>">
                                                    <button type="submit" class="btn btn-outline-danger btn-sm" title="Удалить">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>