<% layout('layout') -%>
<% block('title', notification ? 'Редактирование настройки TeamCity' : 'Создание настройки TeamCity'); -%>

<div class="container my-5">
    <div class="row">
        <div class="col-12 col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-body">
                    <% if (status === 'success') { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <strong>Данные успешно сохранены!</strong>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    <% } else if (status === 'error') { %>
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <strong>Произошла ошибка при сохранении данных.</strong>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    <% } %>

                    <div class="text-center mb-4">
                        <h1 class="h4 mb-1">
                            <%= notification ? 'Редактирование настройки' : 'Создание настройки' %>
                        </h1>
                        <p class="text-muted small mb-0">Уведомления о билдах TeamCity</p>
                    </div>

                    <form method="POST" action="<%= notification ? '/teamcity/update' : '/teamcity/create' %>">
                        <% if (notification) { %>
                            <input type="hidden" name="id" value="<%= notification.id %>">
                        <% } %>

                        <div class="mb-3">
                            <label for="build_config_id" class="form-label">
                                ID конфигурации билда <span class="text-danger">*</span>
                            </label>
                            <input 
                                type="text" 
                                class="form-control" 
                                id="build_config_id" 
                                name="build_config_id" 
                                value="<%= notification ? notification.build_config_id : '' %>"
                                placeholder="CaseProAutotest_Pipeline_DailyRun_NightlyBuilds"
                                required>
                            <div class="form-text">
                                Например: <code>CaseProAutotest_Pipeline_DailyRun_NightlyBuilds</code>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="build_config_name" class="form-label">
                                Название конфигурации билда
                            </label>
                            <input 
                                type="text" 
                                class="form-control" 
                                id="build_config_name" 
                                name="build_config_name" 
                                value="<%= notification ? notification.build_config_name : '' %>"
                                placeholder="Ночные автотесты">
                            <div class="form-text">
                                Если не указано, будет получено автоматически из TeamCity
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="channel_id" class="form-label">
                                ID канала Mattermost <span class="text-danger">*</span>
                            </label>
                            <input 
                                type="text" 
                                class="form-control" 
                                id="channel_id" 
                                name="channel_id" 
                                value="<%= notification ? notification.channel_id : '' %>"
                                placeholder="xxxxxxxxxxxxxxxxxxxxxxxxxx"
                                required>
                            <div class="form-text">
                                ID канала, в который будут отправляться уведомления
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="notify_on" class="form-label">
                                Уведомлять о
                            </label>
                            <select class="form-select" id="notify_on" name="notify_on" required>
                                <option value="all" <%= notification && notification.notify_on === 'all' ? 'selected' : '' %>>
                                    Все билды
                                </option>
                                <option value="success" <%= notification && notification.notify_on === 'success' ? 'selected' : '' %>>
                                    Только успешные
                                </option>
                                <option value="failure" <%= notification && notification.notify_on === 'failure' ? 'selected' : '' %>>
                                    Только неуспешные
                                </option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input 
                                    class="form-check-input" 
                                    type="checkbox" 
                                    id="is_enabled" 
                                    name="is_enabled" 
                                    value="true"
                                    <%= (notification && (notification.is_enabled === 1 || notification.is_enabled === true)) || !notification ? 'checked' : '' %>>
                                <label class="form-check-label" for="is_enabled">
                                    Включено
                                </label>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a href="/teamcity" class="btn btn-secondary">Отмена</a>
                            <button type="submit" class="btn btn-primary">
                                <%= notification ? 'Сохранить изменения' : 'Создать настройку' %>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

