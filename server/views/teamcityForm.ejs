<% layout('layout') -%>
<% block('title', notification ? 'Редактирование настройки TeamCity' : 'Создание настройки TeamCity'); -%>

<div class="container my-5">
    <div class="row">
        <div class="col-12 col-lg-10 mx-auto">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">
                    <i class="bi bi-gear me-2"></i><%= notification ? 'Редактирование настройки TeamCity' : 'Создание настройки TeamCity' %>
                </h2>
                <a href="/teamcity" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left me-1"></i>Назад
                </a>
            </div>

            <% if (status === 'success') { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i><strong>Данные успешно сохранены!</strong>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } else if (status === 'error') { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i><strong>Произошла ошибка при сохранении данных.</strong>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>

            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-bell me-2"></i>Уведомления о билдах TeamCity
                    </h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="<%= notification ? '/teamcity/update' : '/teamcity/create' %>" id="teamcityForm">
                        <% if (notification) { %>
                            <input type="hidden" name="id" value="<%= notification.id %>">
                        <% } %>

                        <div class="mb-3">
                            <label for="build_config_id" class="form-label">
                                <i class="bi bi-tag me-1"></i>ID конфигурации билда <span class="text-danger">*</span>
                            </label>
                            <input 
                                type="text" 
                                class="form-control" 
                                id="build_config_id" 
                                name="build_config_id" 
                                value="<%= notification ? notification.build_config_id : '' %>"
                                placeholder="CaseProAutotest_Pipeline_DailyRun_NightlyBuilds"
                                required>
                        </div>

                        <div class="mb-3">
                            <label for="build_config_name" class="form-label">
                                <i class="bi bi-card-heading me-1"></i>Название конфигурации билда
                            </label>
                            <input 
                                type="text" 
                                class="form-control" 
                                id="build_config_name" 
                                name="build_config_name" 
                                value="<%= notification ? notification.build_config_name : '' %>"
                                placeholder="Ночные автотесты">
                            <div class="form-text">
                                <i class="bi bi-info-circle me-1"></i>Если не указано, будет получено автоматически
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="channel_id" class="form-label">
                                <i class="bi bi-hash me-1"></i>ID канала Mattermost <span class="text-danger">*</span>
                            </label>
                            <input 
                                type="text" 
                                class="form-control" 
                                id="channel_id" 
                                name="channel_id" 
                                value="<%= notification ? notification.channel_id : '' %>"
                                placeholder="xxxxxxxxxxxxxxxxxxxxxxxxxx"
                                required>
                        </div>

                        <div class="mb-3">
                            <label for="notify_on" class="form-label">
                                <i class="bi bi-bell me-1"></i>Уведомлять о
                            </label>
                            <select class="form-select" id="notify_on" name="notify_on" required>
                                <option value="all" <%= notification && notification.notify_on === 'all' ? 'selected' : '' %>>
                                    Все билды
                                </option>
                                <option value="success" <%= notification && notification.notify_on === 'success' ? 'selected' : '' %>>
                                    Только успешные
                                </option>
                                <option value="failure" <%= notification && notification.notify_on === 'failure' ? 'selected' : '' %>>
                                    Только неуспешные
                                </option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input 
                                    class="form-check-input" 
                                    type="checkbox" 
                                    id="is_enabled" 
                                    name="is_enabled" 
                                    value="true"
                                    <%= (notification && (notification.is_enabled === 1 || notification.is_enabled === true)) || !notification ? 'checked' : '' %>>
                                <label class="form-check-label" for="is_enabled">
                                    <i class="bi bi-power me-1"></i>Включено
                                </label>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a href="/teamcity" class="btn btn-secondary">
                                <i class="bi bi-x-circle me-1"></i>Отмена
                            </a>
                            <button type="submit" class="btn btn-primary" id="submitButton">
                                <i class="bi bi-check-circle me-1"></i><%= notification ? 'Сохранить изменения' : 'Создать настройку' %>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('teamcityForm');
        const submitButton = document.getElementById('submitButton');
        
        if (form && submitButton) {
            form.addEventListener('submit', function(e) {
                submitButton.disabled = true;
                submitButton.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Сохранение...';
            });
        }
    });
</script>