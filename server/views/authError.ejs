<% layout('authLayout') -%>
    <% block('title', 'Ошибка авторизации' ); -%>

        <main class="auth-card">
            <section class="auth-card-head">
                <div class="auth-logo bg-danger">
                    <i class="bi bi-shield-x"></i>
                </div>
                <h1 class="auth-title">Ошибка входа</h1>
                <p class="auth-subtitle">Не удалось завершить авторизацию</p>
            </section>
            <section class="auth-card-body">
                <div class="auth-error" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    <%= errorMessage %>
                </div>
                <div class="d-grid gap-2">
                    <a href="/auth/yandex" class="btn btn-primary auth-button">
                        <i class="bi bi-box-arrow-in-right"></i>
                        <span>Попробовать снова</span>
                    </a>
                    <a href="<%= returnUrl || '/' %>" class="btn btn-outline-secondary auth-button">
                        <i class="bi bi-arrow-left"></i>
                        <span>На главную</span>
                    </a>
                </div>
            </section>
        </main>
