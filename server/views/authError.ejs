<% layout('layout') -%>
<% block('title', 'Ошибка авторизации' ); -%>

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card shadow-sm border-danger">
            <div class="card-body text-center py-5">
                <div class="mb-4">
                    <i class="bi bi-exclamation-triangle text-danger" style="font-size: 4rem;"></i>
                </div>
                <h2 class="card-title mb-3">Ошибка авторизации</h2>
                <p class="card-text text-muted mb-4">
                    <%= errorMessage %>
                </p>
                <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                    <a href="/auth/yandex" class="btn btn-primary">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Попробовать снова
                    </a>
                    <a href="<%= returnUrl %>" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Вернуться назад
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

