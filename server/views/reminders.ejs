<% layout('layout') -%>
<% block('title', 'Управление напоминаниями' ); -%>

<div class="container my-5">
    <div class="row">
        <div class="col-12 col-lg-10 mx-auto">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">
                    <i class="bi bi-bell me-2"></i>Управление напоминаниями
                </h2>
                <a href="/" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left me-1"></i>Назад на главную
                </a>
            </div>

            <% if (error) { %>
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i><%= error %>
                </div>
            <% } %>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-plus-circle me-2"></i>Добавить напоминание
                    </h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-info mb-3" role="alert">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Как создать напоминание?</strong><br>
                        Напоминания работают по cron-расписанию в UTC-поясе. Укажите канал, расписание и сообщение.
                        <div class="mt-2">
                            <strong>Примеры cron-расписаний:</strong>
                            <ul class="mb-0 mt-2 small">
                                <li><code>0 9 * * 1-5</code> - Каждый рабочий день в 9:00 UTC</li>
                                <li><code>0 */2 * * *</code> - Каждые 2 часа</li>
                                <li><code>0 0 * * 0</code> - Каждое воскресенье в полночь</li>
                                <li><code>30 14 * * *</code> - Каждый день в 14:30 UTC</li>
                            </ul>
                        </div>
                    </div>
                    <form id="addReminderForm">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="channelId" class="form-label">Channel ID <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="channelId" name="channel_id" 
                                    placeholder="channel_id" required>
                                <div class="form-text">ID канала в Mattermost, куда будет отправляться напоминание</div>
                            </div>
                            <div class="col-md-6">
                                <label for="channelName" class="form-label">Название канала</label>
                                <input type="text" class="form-control" id="channelName" name="channel_name" 
                                    placeholder="Название канала (опционально)">
                                <div class="form-text">Отображаемое название канала (для удобства)</div>
                            </div>
                            <div class="col-md-6">
                                <label for="schedule" class="form-label">Cron-расписание <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="schedule" name="schedule" 
                                    placeholder="0 9 * * 1-5" required>
                                <div class="form-text">Формат: минуты часы день месяц день_недели (UTC)</div>
                            </div>
                            <div class="col-md-6">
                                <label for="message" class="form-label">Сообщение <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="message" name="message" 
                                    placeholder="Время для перерыва на кофе!" required>
                                <div class="form-text">Текст напоминания, который будет отправлен в канал</div>
                            </div>
                        </div>
                        <div class="mt-3">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-plus-circle me-1"></i>Добавить напоминание
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-list-ul me-2"></i>Текущие напоминания
                    </h5>
                </div>
                <div class="card-body">
                    <% if (channels && channels.length > 0) { %>
                        <div class="accordion" id="remindersAccordion">
                            <% channels.forEach((channel, index) => { %>
                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="heading<%= index %>">
                                        <button class="accordion-button <%= index === 0 ? '' : 'collapsed' %>" type="button" 
                                            data-bs-toggle="collapse" data-bs-target="#collapse<%= index %>">
                                            <i class="bi bi-hash me-2"></i><%= channel.name %>
                                            <span class="badge bg-primary ms-2"><%= channel.reminders.length %> напоминание(ий)</span>
                                        </button>
                                    </h2>
                                    <div id="collapse<%= index %>" class="accordion-collapse collapse <%= index === 0 ? 'show' : '' %>" 
                                        data-bs-parent="#remindersAccordion">
                                        <div class="accordion-body">
                                            <div class="table-responsive">
                                                <table class="table table-hover">
                                                    <thead>
                                                        <tr>
                                                            <th style="width: 5%;">ID</th>
                                                            <th style="width: 20%;">Расписание</th>
                                                            <th style="width: 40%;">Сообщение</th>
                                                            <th style="width: 15%;">Автор</th>
                                                            <th style="width: 20%;" class="text-end">Действия</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <% channel.reminders.forEach(reminder => { %>
                                                            <tr data-id="<%= reminder.id %>">
                                                                <td><strong><%= reminder.id %></strong></td>
                                                                <td><code><%= reminder.schedule %></code></td>
                                                                <td><%= reminder.message %></td>
                                                                <td>
                                                                    <small class="text-muted">
                                                                        <%= reminder.user_name || 'System' %>
                                                                    </small>
                                                                </td>
                                                                <td class="text-end">
                                                                    <button type="button" class="btn btn-sm btn-outline-danger remove-reminder-btn" 
                                                                        data-id="<%= reminder.id %>" 
                                                                        data-channel-id="<%= reminder.channel_id %>"
                                                                        data-message="<%= reminder.message %>">
                                                                        <i class="bi bi-trash"></i> Удалить
                                                                    </button>
                                                                </td>
                                                            </tr>
                                                        <% }); %>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <div class="text-center py-4">
                            <i class="bi bi-bell-slash text-muted" style="font-size: 3rem;"></i>
                            <p class="text-muted mt-3">Напоминания не найдены</p>
                            <p class="text-muted small">Добавьте первое напоминание используя форму выше</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Добавление напоминания
    document.getElementById('addReminderForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formData = new FormData(e.target);
        const data = {
            channel_id: formData.get('channel_id').trim(),
            channel_name: formData.get('channel_name')?.trim() || formData.get('channel_id').trim(),
            schedule: formData.get('schedule').trim(),
            message: formData.get('message').trim()
        };
        
        try {
            const response = await fetch('/reminders/api/reminders', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            
            const result = await response.json();
            if (result.success) {
                location.reload();
            } else {
                alert('Ошибка: ' + (result.error || 'Неизвестная ошибка'));
            }
        } catch (error) {
            alert('Ошибка: ' + error.message);
        }
    });
    
    // Удаление напоминания
    document.querySelectorAll('.remove-reminder-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
            const id = btn.dataset.id;
            const channelId = btn.dataset.channelId;
            const message = btn.dataset.message;
            
            if (!confirm(`Удалить напоминание #${id}?\nСообщение: "${message}"`)) {
                return;
            }
            
            try {
                const response = await fetch(`/reminders/api/reminders/${id}?channel_id=${encodeURIComponent(channelId)}`, {
                    method: 'DELETE'
                });
                
                const result = await response.json();
                if (result.success) {
                    location.reload();
                } else {
                    alert('Ошибка: ' + (result.error || 'Неизвестная ошибка'));
                }
            } catch (error) {
                alert('Ошибка: ' + error.message);
            }
        });
    });
</script>

<style>
    .hover-shadow {
        transition: box-shadow 0.2s ease-in-out;
    }
    .hover-shadow:hover {
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
</style>

